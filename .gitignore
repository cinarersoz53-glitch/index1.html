<!DOCTYPE html>
<html>
<head>
    <title>3D Beyin Ağı Karşılaştırması</title>
    <style>
        /* Derin uzay mavisi arka plan */
        body { margin: 0; overflow: hidden; background: radial-gradient(circle, #1a1a2e 0%, #000 100%); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .label {
            position: absolute; text-align: center; width: 33.3%; bottom: 50px;
            color: #ffffff; text-shadow: 0 0 10px rgba(0,255,255,0.5);
            font-size: 14px; letter-spacing: 1px; pointer-events: none;
        }
        .label b { font-size: 18px; display: block; margin-bottom: 5px; color: #00d4ff; }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
</head>
<body>
    <div style="position:relative; width:100%; height:100vh;">
        <div class="label" style="left: 0;"><b>1. SAĞLIKLI BEYİN</b>(Yüksek Boyutlu Geometri)</div>
        <div class="label" style="left: 33.3%;"><b>2. ALZHEIMER MODELİ</b>(Rastgele Parçalanma)</div>
        <div class="label" style="left: 66.6%;"><b>3. D.S. SENDROMU MODELİ</b>(Düşük Boyutlu Geometrik Sınırlama)</div>
    </div>

    <script>
        const scene = new THREE.Scene();
        // Atmosferik derinlik için hafif sis
        scene.fog = new THREE.FogExp2(0x1a1a2e, 0.015);

        const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.set(0, 5, 25);

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setPixelRatio(window.devicePixelRatio);
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.body.appendChild(renderer.domElement);

        const controls = new THREE.OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;

        // --- IŞIKLANDIRMA (Görseldeki parlamayı sağlar) ---
        const mainLight = new THREE.PointLight(0xffffff, 2, 100);
        mainLight.position.set(0, 10, 10);
        scene.add(mainLight);

        const blueLight = new THREE.PointLight(0x00ffff, 1, 50);
        blueLight.position.set(-15, -5, 5);
        scene.add(blueLight);

        scene.add(new THREE.AmbientLight(0x404040, 0.5));

        // --- MATERYALLER (Emissive özelliği ile kendi kendine parlar) ---
        const nodeGeo = new THREE.SphereGeometry(0.18, 24, 24);
        
        const matHealthy = new THREE.MeshPhongMaterial({ color: 0x00ffaa, emissive: 0x00ffaa, emissiveIntensity: 0.5, shininess: 100 });
        const matAlz = new THREE.MeshPhongMaterial({ color: 0xff4444, emissive: 0xff0000, emissiveIntensity: 0.5, shininess: 100 });
        const matDS = new THREE.MeshPhongMaterial({ color: 0xffdd00, emissive: 0xffaa00, emissiveIntensity: 0.5, shininess: 100 });

        const lineMatBlue = new THREE.LineBasicMaterial({ color: 0x00ccff, opacity: 0.4, transparent: true });
        const lineMatRed = new THREE.LineBasicMaterial({ color: 0xff6666, opacity: 0.3, transparent: true });
        const lineMatYellow = new THREE.LineBasicMaterial({ color: 0xffcc00, opacity: 0.3, transparent: true });

        function createNetwork(offset, nodeMat, lineMat, n, prob, dsMode = false) {
            const group = new THREE.Group();
            const nodes = [];
            
            // Nöronları oluştur
            for(let i=0; i<n; i++) {
                const node = new THREE.Mesh(nodeGeo, nodeMat);
                // Küresel bir alana yayılım
                const r = 5;
                node.position.set(
                    (Math.random()-0.5)*r*2,
                    (Math.random()-0.5)*r*2,
                    (Math.random()-0.5)*r*2
                );
                group.add(node);
                nodes.push(node);
            }

            // Bağlantıları oluştur (TDA Klik Mantığı)
            for(let i=0; i<nodes.length; i++) {
                for(let j=i+1; j<nodes.length; j++) {
                    const dist = nodes[i].position.distanceTo(nodes[j].position);
                    let connect = Math.random() < prob;
                    
                    if(dsMode && dist > 3.5) connect = false; // Down Sendromu: Sadece yakın komşularla bağ kurar

                    if(connect) {
                        const geo = new THREE.BufferGeometry().setFromPoints([nodes[i].position, nodes[j].position]);
                        const line = new THREE.Line(geo, lineMat);
                        group.add(line);
                    }
                }
            }
            group.position.x = offset;
            scene.add(group);
            return group;
        }

        // Modelleri yerleştir
        const net1 = createNetwork(-16, matHealthy, lineMatBlue, 35, 0.3); // Sağlıklı: Çok yoğun
        const net2 = createNetwork(0, matAlz, lineMatRed, 25, 0.04);      // Alzheimer: Kopuk ve seyrek
        const net3 = createNetwork(16, matDS, lineMatYellow, 40, 0.4, true); // DS: Yerel kümelenmiş

        function animate() {
            requestAnimationFrame(animate);
            net1.rotation.y += 0.002;
            net2.rotation.y += 0.001;
            net3.rotation.y += 0.0015;
            controls.update();
            renderer.render(scene, camera);
        }
        animate();

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    </script>
</body>
</html>
